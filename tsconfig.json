{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/language-service/main/schema.json",
  "extends": ["@sapphire/ts-config", "@sapphire/ts-config/extra-strict", "@sapphire/ts-config/decorators"],
  "compilerOptions": {
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "preferSchemaOverJson": "off"
        }
      }
    ],
    "outDir": "dist",
    "rootDir": "src",
    "incremental": false,
    "skipLibCheck": true,
    "stripInternal": true,
    "removeComments": true,
    "target": "esnext",
    "moduleResolution": "nodenext"
  },
  "include": ["src"]
}
