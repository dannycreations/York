{
	"name": "york",
	"version": "2.0.0",
	"main": "dist/main.js",
	"author": "dannycreations",
	"license": "GPL-3.0",
	"private": true,
	"scripts": {
		"start:pm2": "pm2 start . --stop-exit-codes 0",
		"start:dev": "npm run clean && tsc-watch --onSuccess \"node .\"",
		"start:debug": "tsx src/main.ts",
		"build": "npm run clean && tsc",
		"clean": "npm run clean:distfiles",
		"clean:distfiles": "npx rimraf --glob \"dist\" \"*.tsbuildinfo\"",
		"update": "npx npm-check-updates -u"
	},
	"dependencies": {
		"@mikro-orm/better-sqlite": "^6.3.6",
		"@vegapunk/core": "^1.0.13",
		"@vegapunk/logger": "^1.0.6",
		"@vegapunk/mikro-orm": "^1.0.10",
		"@vegapunk/request": "^1.0.9",
		"@vegapunk/utilities": "^1.0.12",
		"dotenv": "^16.4.5",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@sapphire/ts-config": "^5.0.1",
		"@types/ws": "^8.5.12",
		"tsc-watch": "^6.2.0",
		"tsx": "^4.17.0",
		"typescript": "^5.5.4"
	}
}
