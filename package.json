{
  "name": "york",
  "version": "2.0.0",
  "main": "dist/main.js",
  "author": "dannycreations",
  "license": "GPL",
  "private": true,
  "scripts": {
    "start:watch": "npm run clean && tsx watch src/main.ts",
    "start:debug": "npm run build && node --inspect-brk .",
    "build": "npm run clean && tsc",
    "check": "npm run format && tsc --noEmit",
    "format": "prettier --write .",
    "clean": "rimraf -g \"*.tsbuildinfo\" \"dist\"",
    "clean:node": "rimraf -g \"*-lock*\" \"node_modules\"",
    "update": "npm-check-updates -u -x got,@types/node",
    "prepare": "husky && effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@vegapunk/utilities": "^1.0.79",
    "dotenv": "^17.4.1",
    "effect": "^3.21.0",
    "got": "11.x",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "user-agents": "^2.1.23"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@sapphire/ts-config": "^5.0.3",
    "@types/node": "24.x",
    "@types/user-agents": "^1.0.4",
    "husky": "^9.1.7",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
